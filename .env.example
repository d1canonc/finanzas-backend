# Copia este archivo como .env y completa los valores

# Microsoft Azure — https://portal.azure.com
AZURE_CLIENT_ID=aqui_tu_client_id
AZURE_CLIENT_SECRET=aqui_tu_client_secret
AZURE_TENANT_ID=common
AZURE_REDIRECT_URI=https://TU-BACKEND.onrender.com/auth/callback

# Anthropic — https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# App
PORT=3000
FRONTEND_URL=https://TU-FRONTEND.vercel.app

# JWT — genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_cadena_larga_aleatoria

# VAPID — genera con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=tu_vapid_public_key
VAPID_PRIVATE_KEY=tu_vapid_private_key
VAPID_EMAIL=mailto:tu@email.com
