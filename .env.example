# ── Microsoft Azure (Outlook) ─────────────────────────────────────────────
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_TENANT_ID=common
AZURE_REDIRECT_URI=https://TU-APP.onrender.com/auth/callback

# ── Anthropic Claude AI ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── App ────────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=https://TU-FRONTEND.vercel.app
JWT_SECRET=genera_con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── Web Push VAPID ─────────────────────────────────────────────────────────
# Genera con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:tu@email.com
